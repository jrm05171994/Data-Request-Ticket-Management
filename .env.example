# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (used by Supabase Auth provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Channel ID of #alerts-client-data (right-click channel → View channel details → bottom).
# Required for the Phase 9 auto-ticket listener.
SLACK_ALERTS_CHANNEL_ID=
# Comma-separated emails that should receive a DM whenever a new request is
# submitted (via web, /submit-data-request, or auto-ticket from the alerts
# channel). Defaults to ryan@kodahealthcare.com when unset. Set to an empty
# string to disable.
NEW_REQUEST_NOTIFY_EMAILS=ryan@kodahealthcare.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
